NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
MAKE_WEBHOOK_URL=
# Opcional — se configurada, o webhook da Kiwify só aceita requisições com
# ?token=<mesmo valor> na URL cadastrada no painel da Kiwify. Sem isso,
# o webhook aceita qualquer POST (comportamento atual, sem quebrar nada).
KIWIFY_WEBHOOK_TOKEN=

# API pública da Kiwify (Fase 2 do roadmap — Revenue Share/Agência).
# Criadas em Apps > API no painel Kiwify. Usadas pra consultar GET
# /sales/{id} e descobrir qual afiliado/revendedor recebeu comissão numa
# venda (ver src/lib/kiwifyApi.ts). Sem estas 3 preenchidas, a atribuição de
# comissão é pulada silenciosamente (getKiwifySale retorna null) — não quebra
# o webhook nem a concessão normal de plano.
KIWIFY_CLIENT_ID=
KIWIFY_CLIENT_SECRET=
KIWIFY_ACCOUNT_ID=

# Gerador de arte com IA (plaquinhas) — chave da OpenAI, usada pra
# gpt-image-2 via /v1/images/edits e /v1/images/generations.
OPENAI_API_KEY=
